<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- ================= WINDOWS INSTALL ================= -->
  <settings pass="windowsPE">
    <component name="Microsoft-Windows-Setup">
      <UserData>
        <AcceptEula>true</AcceptEula>
        <FullName>Administrator</FullName>
        <Organization>Lab</Organization>
      </UserData>
    </component>
  </settings>

  <!-- ================= SYSTEM SETUP ================= -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup">
      <ComputerName>*</ComputerName>
      <TimeZone>GMT Standard Time</TimeZone>
    </component>
  </settings>

  <!-- ================= FIRST BOOT ================= -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-Shell-Setup">

      <AutoLogon>
        <Username>Administrator</Username>
        <Enabled>true</Enabled>
        <Password>
          <Value>Password123!</Value>
          <PlainText>true</PlainText>
        </Password>
      </AutoLogon>

      <FirstLogonCommands>

        <!-- Enable PowerShell Remoting -->
        <SynchronousCommand>
          <Order>1</Order>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Enable-PSRemoting -Force"</CommandLine>
        </SynchronousCommand>

        <!-- Allow basic auth -->
        <SynchronousCommand>
          <Order>2</Order>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Set-Item WSMan:\localhost\Service\Auth\Basic -Value $true"</CommandLine>
        </SynchronousCommand>

        <!-- Allow unencrypted (lab only!) -->
        <SynchronousCommand>
          <Order>3</Order>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Set-Item WSMan:\localhost\Service\AllowUnencrypted -Value $true"</CommandLine>
        </SynchronousCommand>

        <!-- Open WinRM firewall -->
        <SynchronousCommand>
          <Order>4</Order>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Enable-NetFirewallRule -Group '@FirewallAPI.dll,-30267'"</CommandLine>
        </SynchronousCommand>

        <!-- OPTIONAL: set static IP placeholder -->
        <SynchronousCommand>
          <Order>5</Order>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Write-Output 'Ready for Ansible'"</CommandLine>
        </SynchronousCommand>

      </FirstLogonCommands>

    </component>
  </settings>

</unattend>